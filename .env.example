# =============================================================================
# PsicoEspacios Backend — plantilla de variables de entorno
# Copiar a .env y completar valores reales (nunca commitear .env)
# =============================================================================

NODE_ENV=development
PORT=3000

# --- Base de datos (usar DATABASE_URL en producción o variables sueltas en local) ---
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=psicoespacios_user
DATABASE_PASSWORD=psicoespacios_pass
DATABASE_NAME=psicoespacios

# Alternativa usada en algunos scripts legacy (preferir DATABASE_* arriba)
# DB_HOST= DB_USERNAME= DB_PASSWORD= DB_DATABASE=

# --- JWT ---
JWT_SECRET=cambiar-en-produccion
JWT_EXPIRATION=24h

# --- URLs ---
FRONT_URL=http://localhost:3001
API_URL=http://localhost:3000

# --- Flow (pagos) ---
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_COMMERCE_ID=
FLOW_PAYMENT_METHOD=1
FLOW_SUBSCRIPTIONS_CALLBACK_URL=
FLOW_CUSTOMER_REGISTER_RETURN_URL=

# --- Correo (cuenta principal — psicólogos, boxes, etc.) ---
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_FROM_NAME=PsicoEspacios

# --- Correo alternativo (pacientes / centro derivación) ---
MAIL_ALT_HOST=
MAIL_ALT_PORT=587
MAIL_ALT_SECURE=false
MAIL_ALT_USER=
MAIL_ALT_PASS=
MAIL_ALT_FROM=
MAIL_ALT_FROM_NAME=PsicoEspacios

# Ruta a plantillas .hbs (opcional; por defecto src/mail/templates)
# MAIL_TEMPLATES_PATH=

# --- Backblaze B2 / S3-compatible (uploads) ---
BACKBLAZE_ACCESS_KEY_ID=
BACKBLAZE_SECRET_ACCESS_KEY=
BACKBLAZE_ACCOUNT_ID=
BACKBLAZE_APPLICATION_KEY=
BACKBLAZE_BUCKET_NAME=psicoespacios
BACKBLAZE_REGION=us-east-005
BACKBLAZE_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# --- reCAPTCHA (opcional) ---
RECAPTCHA_SECRET_KEY=
RECAPTCHA_V3_MIN_SCORE=0.5
