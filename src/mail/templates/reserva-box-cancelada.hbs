<div class="warning-box">
  <h2>Cancelación de Reserva de Box</h2>
  {{#if canceladaPorAdmin}}
    <p>Hemos cancelado tu reserva para el día <strong>{{fecha}}</strong> a las <strong>{{hora}}</strong> hrs.</p>
  {{else}}
    <p>Hemos recibido la cancelación de tu reserva para el día <strong>{{fecha}}</strong> a las <strong>{{hora}}</strong> hrs.</p>
  {{/if}}
  <p>Si necesitas reagendar, puedes hacerlo desde tu panel.</p>
</div>

